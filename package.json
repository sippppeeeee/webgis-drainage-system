{
  "name": "webgis-drainage-system",
  "version": "1.0.0",
  "description": "WebGIS Application for Urban Drainage Channel Data Management",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "build": "concurrently \"npm run build:frontend\" \"npm run build:backend\"",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "setup": "npm install && cd frontend && npm install && cd ../backend && npm install"
  },
  "keywords": [
    "webgis",
    "drainage",
    "smart-city",
    "geospatial"
  ],
  "author": "Dinas Pekerjaan Umum Kabupaten Brebes",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
